<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GPS LOCATOR"
            android:textColor="#00d4aa"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Solo GPS — nessun dato di rete"
            android:textColor="#888888"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="32dp"/>

        <!-- Status card -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inizializzazione..."
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:background="#2d2d44"
            android:padding="16dp"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Coordinate fields -->
        <TextView
            android:id="@+id/tvLat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Latitudine:  —"
            android:textColor="#00d4aa"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvLon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Longitudine: —"
            android:textColor="#00d4aa"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp"/>

        <!-- Other data -->
        <TextView
            android:id="@+id/tvAlt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Altitudine:  —"
            android:textColor="#aaaaff"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvAccuracy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Precisione:  —"
            android:textColor="#aaaaff"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Velocità:    —"
            android:textColor="#aaaaff"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvBearing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Direzione:   —"
            android:textColor="#aaaaff"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvSatellites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Satelliti in uso: —"
            android:textColor="#ffaa44"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ora fix:     —"
            android:textColor="#888888"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>

    </LinearLayout>
</ScrollView>
